        "Japan": 2.9,
        "Rest of Asia Pacific": 3.5
      },
      {
        "quarter": "Q4 2015",
        "Americas": 21.4,
        "Europe": 10.7,
        "Greater China": 12.7,
        "Japan": 3.6,
        "Rest of Asia Pacific": 3.2
      },
      {
        "quarter": "Q1 2016",
        "Americas": 28.7,
        "Europe": 18,
        "Greater China": 18.9,
        "Japan": 4.9,
        "Rest of Asia Pacific": 5.4
      }
    ]
  },
  "render_script": [
    "const existing = document.querySelector(source_data.container.selector);",
    "const container = existing || (() => {",
    "  const div = document.createElement('div');",
    "  if (source_data.container.selector.startsWith('#')) {",
    "    div.id = source_data.container.selector.slice(1);",
    "  }",
    "  document.body.appendChild(div);",
    "  return div;",
    "})();",
    "",
    "const w = source_data.width;",
    "const h = source_data.height;",
    "const m = source_data.chart.margin;",
    "const innerW = w - m.left - m.right;",
    "const innerH = h - m.top - m.bottom;",
    "",
    "d3.select(container)",
    "  .style('width', w + 'px')",
    "  .style('height', h + 'px')",
    "  .style('background', source_data.container.background)",
    "  .style('margin', '0');",
    "",
    "const svg = d3.select(container)",
    "  .append('svg')",
    "  .attr('width', w)",
    "  .attr('height', h)",
    "  .style('display', 'block')",
    "  .style('background', source_data.chart.background);",
    "",
    "svg.append('text')",
    "  .attr('x', w * source_data.title.x)",
    "  .attr('y', source_data.title.y)",
    "  .attr('text-anchor', 'middle')",
    "  .style('fill', source_data.title.color)",
    "  .style('font-size', source_data.title.fontSize + 'px')",
    "  .style('font-weight', source_data.title.fontWeight)",
    "  .style('font-family', source_data.title.fontFamily)",
    "  .text(source_data.title.text);",
    "",
    "const legendGroup = svg.append('g')",
    "  .attr('transform', `translate(${w * source_data.legend.x}, ${source_data.legend.y})`);",
    "",
    "const legendItems = legendGroup.selectAll('g')",
    "  .data(source_data.series)",
    "  .join('g');",
    "",
    "legendItems.append('rect')",
    "  .attr('width', source_data.legend.swatchW)",
    "  .attr('height', source_data.legend.swatchH)",
    "  .attr('y', -source_data.legend.swatchH + 2)",
    "  .attr('fill', d => d.color);",
    "",
    "legendItems.append('text')",
    "  .attr('x', source_data.legend.swatchW + source_data.legend.textDx)",
    "  .attr('y', 0)",
    "  .attr('dominant-baseline', 'ideographic')",
    "  .style('font-size', source_data.legend.fontSize + 'px')",
    "  .style('font-family', source_data.legend.fontFamily)",
    "  .style('fill', source_data.legend.color)",
    "  .text(d => d.key);",
    "",
    "let accX = 0;",
    "legendItems.each(function(_, i) {",
    "  const gItem = d3.select(this);",
    "  gItem.attr('transform', `translate(${accX}, 0)`);",
    "  const box = this.getBBox();",
    "  accX += box.width + source_data.legend.itemGap;",
    "});",
    "legendGroup.attr('transform', `translate(${(w - (accX - source_data.legend.itemGap)) / 2}, ${source_data.legend.y})`);",
    "",
    "const g = svg.append('g').attr('transform', `translate(${m.left},${m.top})`);",
    "",
    "const x = d3.scalePoint()",
    "  .domain(source_data.data.map(d => d.quarter))",
    "  .range([0, innerW])",
    "  .padding(0.2);",
    "",
    "const y = d3.scaleLinear()",
    "  .domain(source_data.axes.y.domain)",
    "  .range([innerH, 0]);",
    "",
    "const stack = d3.stack().keys(source_data.stack.order);",
    "const stacked = stack(source_data.data);",
    "",
    "const color = new Map(source_data.series.map(d => [d.key, d.color]));",
    "",
    "const area = d3.area()",
    "  .x(d => x(d.data.quarter))",
    "  .y0(d => y(d[0]))",
    "  .y1(d => y(d[1]))",
    "  .curve(d3.curveLinear);",
    "",
    "g.selectAll('.layer')",
    "  .data(stacked)",
    "  .join('path')",
    "  .attr('class', 'layer')",
    "  .attr('d', area)",
    "  .attr('fill', d => color.get(d.key))",
    "  .attr('stroke', source_data.stack.stroke)",
    "  .attr('stroke-width', source_data.stack.strokeWidth);",
    "",
    "const xAxis = d3.axisBottom(x)",
    "  .tickSize(source_data.axes.x.tickSize)",
    "  .tickPadding(8);",
    "",
    "const gx = g.append('g')",
    "  .attr('transform', `translate(0,${innerH})`)",
    "  .call(xAxis);",
    "",
    "gx.selectAll('text')",
    "  .style('fill', source_data.axes.x.tickLabelColor)",
    "  .style('font-size', source_data.axes.x.tickLabelSize + 'px')",
    "  .style('font-family', 'Arial, sans-serif');",
    "",
    "gx.selectAll('line')",
    "  .style('stroke', source_data.axes.x.tickColor)",
    "  .style('stroke-width', 1);",
    "",
    "gx.select('.domain')",
    "  .style('stroke', source_data.axes.x.baselineColor)",
    "  .style('stroke-width', source_data.axes.x.baselineWidth);",
    "",
    "const yAxis = d3.axisLeft(y)",
    "  .tickValues(source_data.axes.y.ticks)",
    "  .tickSize(source_data.axes.y.tickSize)",
    "  .tickPadding(8);",
    "",
    "const gy = g.append('g').call(yAxis);",
    "",
    "gy.selectAll('text')",
    "  .style('fill', source_data.axes.y.tickLabelColor)",
    "  .style('font-size', source_data.axes.y.tickLabelSize + 'px')",
    "  .style('font-family', 'Arial, sans-serif');",
    "",
    "gy.selectAll('line')",
    "  .style('stroke', source_data.axes.y.tickColor)",
    "  .style('stroke-width', 1);",
    "",
    "gy.select('.domain')",
    "  .style('stroke', source_data.axes.y.baselineColor)",
    "  .style('stroke-width', source_data.axes.y.baselineWidth);",
    "",
    "g.append('text')",
    "  .attr('transform', 'rotate(-90)')",
    "  .attr('x', -innerH / 2)",
    "  .attr('y', -source_data.axes.y.labelOffset)",
    "  .attr('text-anchor', 'middle')",
    "  .style('fill', source_data.axes.y.labelColor)",
    "  .style('font-size', source_data.axes.y.labelSize + 'px')",
    "  .style('font-family', 'Arial, sans-serif')",
    "  .text(source_data.axes.y.label);"
  ]
}
