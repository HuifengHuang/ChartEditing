{
  "title": "Brick Facade Preference Shifts Across Neighborhoods",
  "import_script": "<script src=\"https://cdn.jsdelivr.net/npm/d3@7\"></script>",
  "source_data": {
    "container": {
      "width": 842,
      "height": 735,
      "background": {
        "type": "linear",
        "startColor": "#2f2f2f",
        "endColor": "#171717"
      },
      "fontFamily": "Arial, Helvetica, sans-serif"
    },
    "title": {
      "text": "Brick Facade Preference Shifts Across\nNeighborhoods",
      "x": 158,
      "y": 45,
      "fontSize": 28,
      "fontWeight": 700,
      "fill": "#f4f4f4",
      "lineHeight": 34
    },
    "subtitle": {
      "text": "Preference for brick facades varies among neighborhoods, increasing in Oakwood\nand Westwood.",
      "x": 158,
      "y": 107,
      "fontSize": 16,
      "fill": "#f0f0f0",
      "lineHeight": 22
    },
    "accentBar": {
      "x": 112,
      "y": 24,
      "width": 11,
      "height": 110,
      "fill": "#6da3dc",
      "opacity": 0.9
    },
    "legend": {
      "x": 189,
      "y": 157,
      "itemGapX": 98,
      "itemGapY": 28,
      "dotRadius": 5,
      "fontSize": 14,
      "fontWeight": 700,
      "fill": "#f4f4f4"
    },
    "radar": {
      "centerX": 429,
      "centerY": 450,
      "radius": 200,
      "minValue": 0,
      "maxValue": 70,
      "levels": 7,
      "gridStroke": "#dcdcdc",
      "gridStrokeWidth": 0.8,
      "gridOpacity": 0.65,
      "gridDash": "3 5",
      "axisStroke": "#8e8e8e",
      "axisStrokeWidth": 0.8,
      "axisOpacity": 0.35,
      "levelLabel": {
        "xOffset": 8,
        "fontSize": 13,
        "fill": "#d7d7d7",
        "opacity": 0.9
      },
      "axisLabel": {
        "radiusOffset": 28,
        "fontSize": 16,
        "fontWeight": 700,
        "fill": "#f4f4f4"
      },
      "polygon": {
        "strokeWidth": 2,
        "fillOpacity": 0.15
      },
      "point": {
        "radius": 4.2,
        "stroke": "#eeeeee",
        "strokeWidth": 0.8
      }
    },
    "axes": [
      "2010",
      "2014",
      "2018",
      "2020",
      "2022",
      "2024"
    ],
    "series": [
      {
        "name": "Hillcrest",
        "color": "#86b5e6",
        "values": [
          70,
          68,
          66,
          62,
          60,
          52
        ]
      },
      {
        "name": "Westwood",
        "color": "#c8d786",
        "values": [
          45,
          48,
          50,
          54,
          56,
          60
        ]
      },
      {
        "name": "Riverside",
        "color": "#c77bd0",
        "values": [
          60,
          55,
          49,
          46,
          48,
          43
        ]
      },
      {
        "name": "Northgate",
        "color": "#4de0b0",
        "values": [
          52,
          50,
          48,
          45,
          42,
          44
        ]
      },
      {
        "name": "Oakwood",
        "color": "#c46c36",
        "values": [
          35,
          40,
          43,
          46,
          47,
          50
        ]
      },
      {
        "name": "Downtown",
        "color": "#3048e8",
        "values": [
          20,
          20,
          25,
          30,
          30,
          32
        ]
      }
    ]
  },
  "render_script": [
    "function renderChart(config) {",
    "  d3.select(\"body\")",
    "    .style(\"margin\", \"0\")",
    "    .style(\"background\", config.container.background.endColor)",
    "    .style(\"font-family\", config.container.fontFamily);",
    "",
    "  const svg = d3.select(\"body\")",
    "    .append(\"svg\")",
    "    .attr(\"width\", config.container.width)",
    "    .attr(\"height\", config.container.height)",
    "    .attr(\"viewBox\", `0 0 ${config.container.width} ${config.container.height}`)",
    "    .attr(\"xmlns\", \"http://www.w3.org/2000/svg\");",
    "",
    "  const defs = svg.append(\"defs\");",
    "",
    "  const bgGradient = defs.append(\"linearGradient\")",
    "    .attr(\"id\", \"bgGradient\")",
    "    .attr(\"x1\", \"0%\")",
    "    .attr(\"y1\", \"0%\")",
    "    .attr(\"x2\", \"0%\")",
    "    .attr(\"y2\", \"100%\");",
    "",
    "  bgGradient.append(\"stop\")",
    "    .attr(\"offset\", \"0%\")",
    "    .attr(\"stop-color\", config.container.background.startColor);",
    "",
    "  bgGradient.append(\"stop\")",
    "    .attr(\"offset\", \"100%\")",
    "    .attr(\"stop-color\", config.container.background.endColor);",
    "",
    "  svg.append(\"rect\")",
    "    .attr(\"width\", config.container.width)",
    "    .attr(\"height\", config.container.height)",
    "    .attr(\"fill\", \"url(#bgGradient)\");",
    "",
    "  svg.append(\"rect\")",
    "    .attr(\"x\", config.accentBar.x)",
    "    .attr(\"y\", config.accentBar.y)",
    "    .attr(\"width\", config.accentBar.width)",
    "    .attr(\"height\", config.accentBar.height)",
    "    .attr(\"fill\", config.accentBar.fill)",
    "    .attr(\"opacity\", config.accentBar.opacity);",
    "",
    "  drawMultilineText(svg, config.title);",
    "  drawMultilineText(svg, config.subtitle);",
    "",
    "  drawLegend(svg, config);",
    "  drawRadar(svg, config);",
    "}",
    "",
    "function drawMultilineText(svg, cfg) {",
    "  const text = svg.append(\"text\")",
    "    .attr(\"x\", cfg.x)",
    "    .attr(\"y\", cfg.y)",
    "    .attr(\"fill\", cfg.fill)",
    "    .attr(\"font-size\", cfg.fontSize)",
    "    .attr(\"font-weight\", cfg.fontWeight || 400)",
    "    .attr(\"font-family\", source_data.container.fontFamily);",
    "",
    "  cfg.text.split(\"\\n\").forEach((line, i) => {",
    "    text.append(\"tspan\")",
    "      .attr(\"x\", cfg.x)",
    "      .attr(\"dy\", i === 0 ? 0 : cfg.lineHeight)",
    "      .text(line);",
    "  });",
    "}",
    "",
    "function drawLegend(svg, config) {",
    "  const legend = config.legend;",
    "",
    "  const items = svg.append(\"g\")",
    "    .attr(\"transform\", `translate(${legend.x}, ${legend.y})`);",
    "",
    "  config.series.forEach((d, i) => {",
    "    const col = i % 4;",
    "    const row = Math.floor(i / 4);",
    "",
    "    const g = items.append(\"g\")",
    "      .attr(\"transform\", `translate(${col * legend.itemGapX}, ${row * legend.itemGapY})`);",
    "",
    "    g.append(\"circle\")",
    "      .attr(\"cx\", 0)",
    "      .attr(\"cy\", 0)",
    "      .attr(\"r\", legend.dotRadius)",
    "      .attr(\"fill\", d.color);",
    "",
    "    g.append(\"text\")",
    "      .attr(\"x\", 10)",
    "      .attr(\"y\", 5)",
    "      .attr(\"fill\", legend.fill)",
    "      .attr(\"font-size\", legend.fontSize)",
    "      .attr(\"font-weight\", legend.fontWeight)",
    "      .attr(\"font-family\", config.container.fontFamily)",
    "      .text(d.name);",
    "  });",
    "}",
    "",
    "function drawRadar(svg, config) {",
    "  const radar = config.radar;",
    "  const axes = config.axes;",
    "  const axisCount = axes.length;",
    "  const angleSlice = Math.PI * 2 / axisCount;",
    "",
    "  const rScale = d3.scaleLinear()",
    "    .domain([radar.minValue, radar.maxValue])",
    "    .range([0, radar.radius]);",
    "",
    "  const radarGroup = svg.append(\"g\")",
    "    .attr(\"transform\", `translate(${radar.centerX}, ${radar.centerY})`);",
    "",
    "  function angle(i) {",
    "    return -Math.PI / 2 + i * angleSlice;",
    "  }",
    "",
    "  function point(value, i) {",
    "    const r = rScale(value);",
    "    return [",
    "      Math.cos(angle(i)) * r,",
    "      Math.sin(angle(i)) * r",
    "    ];",
    "  }",
    "",
    "  for (let level = 1; level <= radar.levels; level++) {",
    "    const value = radar.maxValue / radar.levels * level;",
    "    const radius = rScale(value);",
    "",
    "    radarGroup.append(\"circle\")",
    "      .attr(\"cx\", 0)",
    "      .attr(\"cy\", 0)",
    "      .attr(\"r\", radius)",
    "      .attr(\"fill\", \"none\")",
    "      .attr(\"stroke\", radar.gridStroke)",
    "      .attr(\"stroke-width\", radar.gridStrokeWidth)",
    "      .attr(\"stroke-opacity\", radar.gridOpacity)",
    "      .attr(\"stroke-dasharray\", radar.gridDash);",
    "  }",
    "",
    "  radarGroup.append(\"circle\")",
    "    .attr(\"cx\", 0)",
    "    .attr(\"cy\", 0)",
    "    .attr(\"r\", 1.5)",
    "    .attr(\"fill\", radar.gridStroke)",
    "    .attr(\"opacity\", 0.7);",
    "",
    "  for (let level = 0; level <= radar.levels; level++) {",
    "    const value = radar.maxValue / radar.levels * level;",
    "    const y = -rScale(value);",
    "",
    "    radarGroup.append(\"text\")",
    "      .attr(\"x\", radar.levelLabel.xOffset)",
    "      .attr(\"y\", y + 4)",
    "      .attr(\"fill\", radar.levelLabel.fill)",
    "      .attr(\"opacity\", radar.levelLabel.opacity)",
    "      .attr(\"font-size\", radar.levelLabel.fontSize)",
    "      .attr(\"font-family\", config.container.fontFamily)",
    "      .text(Math.round(value));",
    "  }",
    "",
    "  axes.forEach((axis, i) => {",
    "    const end = point(radar.maxValue, i);",
    "",
    "    radarGroup.append(\"line\")",
    "      .attr(\"x1\", 0)",
    "      .attr(\"y1\", 0)",
    "      .attr(\"x2\", end[0])",
    "      .attr(\"y2\", end[1])",
    "      .attr(\"stroke\", radar.axisStroke)",
    "      .attr(\"stroke-width\", radar.axisStrokeWidth)",
    "      .attr(\"stroke-opacity\", radar.axisOpacity);",
    "",
    "    const labelR = radar.radius + radar.axisLabel.radiusOffset;",
    "    const labelX = Math.cos(angle(i)) * labelR;",
    "    const labelY = Math.sin(angle(i)) * labelR;",
    "",
    "    radarGroup.append(\"text\")",
    "      .attr(\"x\", labelX)",
    "      .attr(\"y\", labelY)",
    "      .attr(\"fill\", radar.axisLabel.fill)",
    "      .attr(\"font-size\", radar.axisLabel.fontSize)",
    "      .attr(\"font-weight\", radar.axisLabel.fontWeight)",
    "      .attr(\"font-family\", config.container.fontFamily)",
    "      .attr(\"text-anchor\", getTextAnchor(i, axisCount))",
    "      .attr(\"dominant-baseline\", getDominantBaseline(i, axisCount))",
    "      .text(axis);",
    "  });",
    "",
    "  const line = d3.line()",
    "    .x(d => d[0])",
    "    .y(d => d[1])",
    "    .curve(d3.curveLinearClosed);",
    "",
    "  config.series.forEach(series => {",
    "    const points = series.values.map((v, i) => point(v, i));",
    "",
    "    radarGroup.append(\"path\")",
    "      .datum(points)",
    "      .attr(\"d\", line)",
    "      .attr(\"fill\", series.color)",
    "      .attr(\"fill-opacity\", radar.polygon.fillOpacity)",
    "      .attr(\"stroke\", series.color)",
    "      .attr(\"stroke-width\", radar.polygon.strokeWidth)",
    "      .attr(\"stroke-linejoin\", \"round\")",
    "      .attr(\"stroke-linecap\", \"round\");",
    "",
    "    radarGroup.selectAll(`.point-${series.name}`)",
    "      .data(points)",
    "      .enter()",
    "      .append(\"circle\")",
    "      .attr(\"cx\", d => d[0])",
    "      .attr(\"cy\", d => d[1])",
    "      .attr(\"r\", radar.point.radius)",
    "      .attr(\"fill\", series.color)",
    "      .attr(\"stroke\", radar.point.stroke)",
    "      .attr(\"stroke-width\", radar.point.strokeWidth);",
    "  });",
    "}",
    "",
    "function getTextAnchor(i, axisCount) {",
    "  if (i === 0 || i === axisCount / 2) return \"middle\";",
    "  if (i < axisCount / 2) return \"start\";",
    "  return \"end\";",
    "}",
    "",
    "function getDominantBaseline(i, axisCount) {",
    "  if (i === 0) return \"auto\";",
    "  if (i === axisCount / 2) return \"hanging\";",
    "  return \"middle\";",
    "}",
    "",
    "renderChart(source_data);"
  ]
}
