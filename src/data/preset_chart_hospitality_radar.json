{
  "title": "Gender Imbalance in Hospitality Industry Roles",
  "import_script": "<script src=\"https://cdn.jsdelivr.net/npm/d3@7\"></script>",
  "source_data": {
    "canvas": {
      "width": 825,
      "height": 841,
      "background": {
        "top": "#2a2d34",
        "middle": "#202127",
        "bottom": "#15161b"
      }
    },
    "radar": {
      "centerX": 432,
      "centerY": 353,
      "radius": 250,
      "maxValue": 300,
      "levels": [
        50,
        100,
        150,
        200,
        250,
        300
      ],
      "categories": [
        "Chef",
        "Manager",
        "Server",
        "Bartender",
        "Housekeeping",
        "Front Desk"
      ],
      "grid": {
        "stroke": "#d7d7d7",
        "strokeWidth": 0.8,
        "strokeOpacity": 0.75,
        "dashArray": "3 5"
      },
      "axis": {
        "stroke": "#d8d8d8",
        "strokeWidth": 0.8,
        "strokeOpacity": 0.75
      },
      "tickLabel": {
        "fill": "#e8e8e8",
        "fontSize": 13,
        "fontFamily": "Arial, sans-serif",
        "offsetX": 4,
        "offsetY": 0
      },
      "categoryLabel": {
        "fill": "#ffffff",
        "fontSize": 16,
        "fontWeight": "700",
        "fontFamily": "Arial, sans-serif",
        "offset": 18
      }
    },
    "legend": {
      "x": 313,
      "y": 41,
      "itemGap": 110,
      "dotRadius": 5,
      "textOffsetX": 10,
      "fill": "#ffffff",
      "fontSize": 14,
      "fontWeight": "700",
      "fontFamily": "Arial, sans-serif"
    },
    "seriesStyle": {
      "strokeWidth": 2,
      "fillOpacity": 0.22,
      "pointRadius": 4.3,
      "pointStroke": "#ffffff",
      "pointStrokeWidth": 1
    },
    "series": [
      {
        "name": "Female",
        "color": "#bcd9fb",
        "values": [
          45,
          120,
          300,
          75,
          260,
          130
        ]
      },
      {
        "name": "Male",
        "color": "#9b57f0",
        "values": [
          150,
          85,
          220,
          115,
          30,
          75
        ]
      },
      {
        "name": "Other",
        "color": "#35e0cf",
        "values": [
          8,
          12,
          20,
          10,
          6,
          5
        ]
      }
    ],
    "title": {
      "text": "Gender Imbalance in Hospitality Industry Roles",
      "x": 95,
      "y": 666,
      "fill": "#ffffff",
      "fontSize": 28,
      "fontWeight": "800",
      "fontFamily": "Arial, sans-serif"
    },
    "subtitle": {
      "text": "Percentage of female employees (who dominate Housekeeping and Servers) in the\\nhospitality industry.",
      "x": 95,
      "y": 698,
      "fill": "#ffffff",
      "fontSize": 16,
      "lineHeight": 21,
      "fontWeight": "400",
      "fontFamily": "Arial, sans-serif"
    }
  },
  "render_script": [
    "function renderChart(config) {",
    "  d3.select(\"body\")",
    "    .style(\"margin\", \"0\")",
    "    .style(\"background\", config.canvas.background.bottom)",
    "    .style(\"overflow\", \"hidden\");",
    "",
    "  const svg = d3.select(\"body\")",
    "    .append(\"svg\")",
    "    .attr(\"width\", config.canvas.width)",
    "    .attr(\"height\", config.canvas.height);",
    "",
    "  const defs = svg.append(\"defs\");",
    "",
    "  const bgGradient = defs.append(\"linearGradient\")",
    "    .attr(\"id\", \"bgGradient\")",
    "    .attr(\"x1\", \"0%\")",
    "    .attr(\"y1\", \"0%\")",
    "    .attr(\"x2\", \"0%\")",
    "    .attr(\"y2\", \"100%\");",
    "",
    "  bgGradient.append(\"stop\")",
    "    .attr(\"offset\", \"0%\")",
    "    .attr(\"stop-color\", config.canvas.background.top);",
    "",
    "  bgGradient.append(\"stop\")",
    "    .attr(\"offset\", \"55%\")",
    "    .attr(\"stop-color\", config.canvas.background.middle);",
    "",
    "  bgGradient.append(\"stop\")",
    "    .attr(\"offset\", \"100%\")",
    "    .attr(\"stop-color\", config.canvas.background.bottom);",
    "",
    "  svg.append(\"rect\")",
    "    .attr(\"x\", 0)",
    "    .attr(\"y\", 0)",
    "    .attr(\"width\", config.canvas.width)",
    "    .attr(\"height\", config.canvas.height)",
    "    .attr(\"fill\", \"url(#bgGradient)\");",
    "",
    "  const radarGroup = svg.append(\"g\")",
    "    .attr(\"transform\", `translate(${config.radar.centerX}, ${config.radar.centerY})`);",
    "",
    "  const categories = config.radar.categories;",
    "  const total = categories.length;",
    "  const angleSlice = (Math.PI * 2) / total;",
    "",
    "  function angle(index) {",
    "    return index * angleSlice - Math.PI / 2;",
    "  }",
    "",
    "  function radiusScale(value) {",
    "    return (value / config.radar.maxValue) * config.radar.radius;",
    "  }",
    "",
    "  function pointPosition(index, value) {",
    "    const r = radiusScale(value);",
    "    return {",
    "      x: Math.cos(angle(index)) * r,",
    "      y: Math.sin(angle(index)) * r,",
    "    };",
    "  }",
    "",
    "  config.radar.levels.forEach((level) => {",
    "    radarGroup.append(\"circle\")",
    "      .attr(\"cx\", 0)",
    "      .attr(\"cy\", 0)",
    "      .attr(\"r\", radiusScale(level))",
    "      .attr(\"fill\", \"none\")",
    "      .attr(\"stroke\", config.radar.grid.stroke)",
    "      .attr(\"stroke-width\", config.radar.grid.strokeWidth)",
    "      .attr(\"stroke-opacity\", config.radar.grid.strokeOpacity)",
    "      .attr(\"stroke-dasharray\", config.radar.grid.dashArray);",
    "  });",
    "",
    "  categories.forEach((category, i) => {",
    "    const outer = pointPosition(i, config.radar.maxValue);",
    "",
    "    radarGroup.append(\"line\")",
    "      .attr(\"x1\", 0)",
    "      .attr(\"y1\", 0)",
    "      .attr(\"x2\", outer.x)",
    "      .attr(\"y2\", outer.y)",
    "      .attr(\"stroke\", config.radar.axis.stroke)",
    "      .attr(\"stroke-width\", config.radar.axis.strokeWidth)",
    "      .attr(\"stroke-opacity\", config.radar.axis.strokeOpacity);",
    "",
    "    const labelR = config.radar.radius + config.radar.categoryLabel.offset;",
    "    const labelX = Math.cos(angle(i)) * labelR;",
    "    const labelY = Math.sin(angle(i)) * labelR;",
    "",
    "    let anchor = \"middle\";",
    "    if (labelX > 20) anchor = \"start\";",
    "    if (labelX < -20) anchor = \"end\";",
    "",
    "    radarGroup.append(\"text\")",
    "      .attr(\"x\", labelX)",
    "      .attr(\"y\", labelY)",
    "      .attr(\"text-anchor\", anchor)",
    "      .attr(\"dominant-baseline\", \"middle\")",
    "      .attr(\"fill\", config.radar.categoryLabel.fill)",
    "      .style(\"font-size\", `${config.radar.categoryLabel.fontSize}px`)",
    "      .style(\"font-weight\", config.radar.categoryLabel.fontWeight)",
    "      .style(\"font-family\", config.radar.categoryLabel.fontFamily)",
    "      .text(category);",
    "  });",
    "",
    "  config.radar.levels.forEach((level) => {",
    "    radarGroup.append(\"text\")",
    "      .attr(\"x\", config.radar.tickLabel.offsetX)",
    "      .attr(\"y\", -radiusScale(level) + config.radar.tickLabel.offsetY)",
    "      .attr(\"fill\", config.radar.tickLabel.fill)",
    "      .style(\"font-size\", `${config.radar.tickLabel.fontSize}px`)",
    "      .style(\"font-family\", config.radar.tickLabel.fontFamily)",
    "      .text(level);",
    "  });",
    "",
    "  const lineGenerator = d3.line()",
    "    .x((d) => d.x)",
    "    .y((d) => d.y)",
    "    .curve(d3.curveLinearClosed);",
    "",
    "  config.series.forEach((series) => {",
    "    const points = series.values.map((value, i) => pointPosition(i, value));",
    "",
    "    radarGroup.append(\"path\")",
    "      .datum(points)",
    "      .attr(\"d\", lineGenerator)",
    "      .attr(\"fill\", series.color)",
    "      .attr(\"fill-opacity\", config.seriesStyle.fillOpacity)",
    "      .attr(\"stroke\", series.color)",
    "      .attr(\"stroke-width\", config.seriesStyle.strokeWidth);",
    "",
    "    radarGroup.selectAll(`.point-${series.name}`)",
    "      .data(points)",
    "      .enter()",
    "      .append(\"circle\")",
    "      .attr(\"cx\", (d) => d.x)",
    "      .attr(\"cy\", (d) => d.y)",
    "      .attr(\"r\", config.seriesStyle.pointRadius)",
    "      .attr(\"fill\", series.color)",
    "      .attr(\"stroke\", config.seriesStyle.pointStroke)",
    "      .attr(\"stroke-width\", config.seriesStyle.pointStrokeWidth);",
    "  });",
    "",
    "  const legendGroup = svg.append(\"g\")",
    "    .attr(\"transform\", `translate(${config.legend.x}, ${config.legend.y})`);",
    "",
    "  config.series.forEach((series, i) => {",
    "    const item = legendGroup.append(\"g\")",
    "      .attr(\"transform\", `translate(${i * config.legend.itemGap}, 0)`);",
    "",
    "    item.append(\"circle\")",
    "      .attr(\"cx\", 0)",
    "      .attr(\"cy\", 0)",
    "      .attr(\"r\", config.legend.dotRadius)",
    "      .attr(\"fill\", series.color);",
    "",
    "    item.append(\"text\")",
    "      .attr(\"x\", config.legend.textOffsetX)",
    "      .attr(\"y\", 1)",
    "      .attr(\"dominant-baseline\", \"middle\")",
    "      .attr(\"fill\", config.legend.fill)",
    "      .style(\"font-size\", `${config.legend.fontSize}px`)",
    "      .style(\"font-weight\", config.legend.fontWeight)",
    "      .style(\"font-family\", config.legend.fontFamily)",
    "      .text(series.name);",
    "  });",
    "",
    "  svg.append(\"text\")",
    "    .attr(\"x\", config.title.x)",
    "    .attr(\"y\", config.title.y)",
    "    .attr(\"fill\", config.title.fill)",
    "    .style(\"font-size\", `${config.title.fontSize}px`)",
    "    .style(\"font-weight\", config.title.fontWeight)",
    "    .style(\"font-family\", config.title.fontFamily)",
    "    .text(config.title.text);",
    "",
    "  const subtitle = svg.append(\"text\")",
    "    .attr(\"x\", config.subtitle.x)",
    "    .attr(\"y\", config.subtitle.y)",
    "    .attr(\"fill\", config.subtitle.fill)",
    "    .style(\"font-size\", `${config.subtitle.fontSize}px`)",
    "    .style(\"font-weight\", config.subtitle.fontWeight)",
    "    .style(\"font-family\", config.subtitle.fontFamily);",
    "",
    "  config.subtitle.text.split(\"\\\\n\").forEach((line, i) => {",
    "    subtitle.append(\"tspan\")",
    "      .attr(\"x\", config.subtitle.x)",
    "      .attr(\"dy\", i === 0 ? 0 : config.subtitle.lineHeight)",
    "      .text(line);",
    "  });",
    "}",
    "",
    "renderChart(source_data);"
  ]
}
